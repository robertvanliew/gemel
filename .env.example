# Gemel configuration — copy to .env and fill in. Never commit .env.

# --- Market data source ---
# yfinance (default, no key) or alpaca
DATA_SOURCE=yfinance

# --- Alpaca Market Data (optional; only needed if DATA_SOURCE=alpaca) ---
# Get paper-account keys: app.alpaca.markets -> Paper Trading -> API Keys
# READ-ONLY market data only. Gemel never places orders.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Paper account size for the 2% per-trade max-loss cap ---
ACCOUNT_SIZE=35000
